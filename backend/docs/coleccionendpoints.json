    {
      "name": "Cliente",
      "item": [
        {
          "name": "Solicitar servicio",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token_cliente}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"descripcion\": \"Recolección de cartón y plástico, 2 bolsas grandes\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/servicios",
              "host": ["{{base_url}}"],
              "path": ["servicios"]
            }
          }
        },
        {
          "name": "Mis servicios",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token_cliente}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/servicios",
              "host": ["{{base_url}}"],
              "path": ["servicios"]
            }
          }
        },
        {
          "name": "Detalle de servicio",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token_cliente}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/servicios/{{servicio_id}}",
              "host": ["{{base_url}}"],
              "path": ["servicios", "{{servicio_id}}"]
            }
          }
        },
        {
          "name": "Calificar servicio",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token_cliente}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"puntuacion\": 5,\n    \"comentario\": \"Muy puntual y organizado\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/servicios/{{servicio_id}}/calificar",
              "host": ["{{base_url}}"],
              "path": ["servicios", "{{servicio_id}}", "calificar"]
            }
          }
        }
      ]
    },
    {
      "name": "Reciclador",
      "item": [
        {
          "name": "Ver servicios asignados",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token_reciclador}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/reciclador/servicios",
              "host": ["{{base_url}}"],
              "path": ["reciclador", "servicios"]
            }
          }
        },
        {
          "name": "Aceptar servicio",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token_reciclador}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/reciclador/servicios/{{servicio_id}}/aceptar",
              "host": ["{{base_url}}"],
              "path": ["reciclador", "servicios", "{{servicio_id}}", "aceptar"]
            }
          }
        },
        {
          "name": "Rechazar servicio",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token_reciclador}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/reciclador/servicios/{{servicio_id}}/rechazar",
              "host": ["{{base_url}}"],
              "path": ["reciclador", "servicios", "{{servicio_id}}", "rechazar"]
            }
          }
        },
        {
          "name": "Completar servicio (subir fotos)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token_reciclador}}"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "fotos",
                  "type": "file",
                  "src": "ruta_del_archivo.jpg",
                  "contentType": "image/jpeg"
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/reciclador/servicios/{{servicio_id}}/completar",
              "host": ["{{base_url}}"],
              "path": ["reciclador", "servicios", "{{servicio_id}}", "completar"]
            }
          }
        }
      ]
    },
