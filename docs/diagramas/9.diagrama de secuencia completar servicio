
@startuml seq_completar_servicio
!define DIRECTION top to bottom
skinparam backgroundColor #FEFEFE

participant Reciclador
participant Frontend
participant "FastAPI\nBackend"
participant "Auth Module"
participant "Use Case"
participant "SQLite DB"
participant "File Storage"

Reciclador -> Frontend: Click "Completar Servicio"
Frontend -> Reciclador: Muestra upload de fotos

Reciclador -> Frontend: Arrastra fotos
Frontend -> "FastAPI\nBackend": POST /services/1/complete\n{token, files=[img1, img2]}

"FastAPI\nBackend" -> "Auth Module": verify_recycler(token)
"Auth Module" --> "FastAPI\nBackend": recycler validated

"FastAPI\nBackend" -> "Use Case": complete_service(service_id, recycler_id, files)

"Use Case" -> "Use Case": validate_files(mimetype, size)

loop Para cada archivo
    "Use Case" -> "File Storage": save_file(uuid.jpg)
    "File Storage" --> "Use Case": file_path
    "Use Case" -> "SQLite DB": INSERT INTO evidences\n(service_id, file_path)
end

"Use Case" -> "SQLite DB": UPDATE services\nSET status='completed'

"Use Case" --> "FastAPI\nBackend": ServiceCompleted{status, evidences=[]}
"FastAPI\nBackend" --> Frontend: 200 OK
Frontend --> Reciclador: "Servicio completado"

@enduml
